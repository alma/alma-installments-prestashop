{
    "name": "alma/alma-instalments-prestashop",
    "description": "Payment method module to integrate Alma in PrestaShop",
    "type": "prestashop-module",
    "require-dev": {
        "phpunit/phpunit": "^8.5",
        "mockery/mockery": "^1.3",
        "phpcompatibility/php-compatibility": "^9.3",
        "prestashop/php-dev-tools": "~4.0",
        "prestashop/autoindex": "^2.0"
    },
    "require": {
        "php": "^7.4 || ~8.0 || ~8.1",
        "alma/alma-php-client": "3.0.*|dev-feature/3.0",
        "ext-json": "*",
        "ext-openssl": "*",
        "prestashop/prestashop-accounts-installer": "^1.0",
        "prestashop/module-lib-service-container": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Alma\\Module\\": "src/",
            "Alma\\Api\\": "vendor/alma/alma-php-client/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Alma\\Tests\\": "tests/"
        }
    },
    "config": {
        "prepend-autoloader": false,
        "optimize-autoloader": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "php-cs": "php vendor/bin/php-cs-fixer fix --dry-run",
        "php-cs-fixer": "php vendor/bin/php-cs-fixer fix",
        "php-compatibility": "vendor/bin/phpcs -p . --standard=PHPCompatibility -s --runtime-set testVersion 5.6-8.1 --ignore=\\*/vendor/\\*"
    },
    "extra": {
        "installer-name": "alma"
    },
    "authors": [
        {
            "name": "Alma",
            "email": "support@almapay.com"
        }
    ],
    "license": "MIT",
    "minimum-stability": "dev"
}
